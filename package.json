{
  "type": "module",
  "scripts": {
    "upgrade-latest": "npx npm-check-updates -u",
    "clean": "bash scripts/clean.sh",
    "lint": "tsc && eslint lib/**/*.ts",
    "format": "prettier --write '**/*.{js,jsx,ts,tsx,json,yaml,md}'",
    "dist": "bash scripts/dist.sh",
    "test": "npm run dist && cd lib/test && npm i && npm t",
    "publish:dry": "npm run dist && npm publish ./dist --dry-run --access public",
    "publish": "npm publish ./dist --access public"
  },
  "dependencies": {
    "esbuild": "^0.28.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^25.8.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  },
  "license": "MIT"
}
